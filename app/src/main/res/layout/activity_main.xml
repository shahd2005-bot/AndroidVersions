<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#FFFF00"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/showCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="120sp"
        android:textColor="@android:color/black"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <android.widget.Button
        android:id="@+id/buttonToast"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:text="Toast"
        android:onClick="showToast"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_blue_light"
        app:layout_constraintTop_toTopOf="@id/showCount"
        app:layout_constraintBottom_toTopOf="@id/buttonZero"
        app:layout_constraintEnd_toStartOf="@id/showCount"
        android:layout_marginEnd="16dp" />

    <android.widget.Button
        android:id="@+id/buttonZero"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:text="Zero"
        android:onClick="showZero"
        android:textColor="@android:color/white"
        android:background="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/buttonToast"
        app:layout_constraintBottom_toTopOf="@id/buttonCount"
        app:layout_constraintEnd_toStartOf="@id/showCount"
        android:layout_marginEnd="16dp" />

    <android.widget.Button
        android:id="@+id/buttonCount"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:text="Count"
        android:onClick="showCount"
        android:textColor="@android:color/white"
        android:background="@android:color/holo_green_light"
        app:layout_constraintTop_toBottomOf="@id/buttonZero"
        app:layout_constraintBottom_toBottomOf="@id/showCount"
        app:layout_constraintEnd_toStartOf="@id/showCount"
        android:layout_marginEnd="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>